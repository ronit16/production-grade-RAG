# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ProductionRAG
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-to-a-random-32-char-string-minimum
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object Storage (MinIO — self-hosted, S3-compatible) ───────────────────────
S3_BUCKET=rag-documents
S3_PREFIX=rag-documents
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Qdrant (vector DB — dense + sparse + hybrid RRF) ─────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                        # leave blank for local; required for Qdrant Cloud
QDRANT_COLLECTION=rag_chunks
QDRANT_DENSE_DIM=1536                  # must match EMBEDDING_MODEL output dims
QDRANT_SPARSE_MODEL=Qdrant/bm25        # fastembed BM25 sparse model

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_BATCH_SIZE=256

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                  # primary LLM + embeddings
GEMINI_API_KEY=AIza...                 # fallback LLM (Google AI Studio — free tier)
PRIMARY_LLM=openai/gpt-4o
FALLBACK_LLM=gemini/gemini-1.5-pro

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem
